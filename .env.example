# Django settings
# Set DJANGO_DEBUG=true for local development (enables the dev-only SECRET_KEY fallback).
# Set to false and provide a real DJANGO_SECRET_KEY for production / Docker Compose.
DJANGO_SECRET_KEY=changeme-replace-with-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (used by both the db service and the web service)
POSTGRES_DB=cialettravel
POSTGRES_USER=cialettravel
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=db
POSTGRES_PORT=5432
